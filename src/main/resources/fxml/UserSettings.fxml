<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="520.0" prefWidth="480.0" spacing="4.0"
      style="-fx-background-color: #F5F5F5; -fx-padding: 28;"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.wiseplanner.gui.controller.UserSettingsController">
    <children>
        <Label text="User Settings"
               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2D3B45;">
            <VBox.margin><Insets bottom="18.0"/></VBox.margin>
        </Label>

        <Label text="Name" style="-fx-font-weight: bold; -fx-text-fill: #2D3B45;"/>
        <TextField fx:id="nameField" promptText="Your name">
            <VBox.margin><Insets bottom="12.0" top="4.0"/></VBox.margin>
        </TextField>

        <Label text="Canvas Token" style="-fx-font-weight: bold; -fx-text-fill: #2D3B45;"/>
        <TextField fx:id="tokenField" promptText="Paste your Canvas access token">
            <VBox.margin><Insets bottom="12.0" top="4.0"/></VBox.margin>
        </TextField>

        <Label text="Gemini API Key" style="-fx-font-weight: bold; -fx-text-fill: #2D3B45;"/>
        <Label text="Optional — enables AI grade analysis and daily insights"
               style="-fx-text-fill: #6B7280; -fx-font-size: 11px;"/>
        <Label text="Get a free key at: https://aistudio.google.com"
               style="-fx-text-fill: #0770A3; -fx-font-size: 11px; -fx-cursor: hand;">
            <VBox.margin><Insets bottom="2.0"/></VBox.margin>
        </Label>
        <TextField fx:id="geminiKeyField" promptText="Paste your Gemini API key here">
            <VBox.margin><Insets bottom="16.0" top="4.0"/></VBox.margin>
        </TextField>

        <Label fx:id="statusLabel" text="" style="-fx-font-size: 12px;">
            <VBox.margin><Insets bottom="6.0"/></VBox.margin>
        </Label>

        <Button text="Save Changes" onAction="#onSaveButtonClick"
                maxWidth="1.7976931348623157E308"/>
    </children>
</VBox>