<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="anchorPane" prefHeight="704.0" prefWidth="1302.0" style="-fx-background-color: #ffffff;" stylesheets="@../css/Common.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.wiseplanner.gui.controller.TasksController">
    <top>
        <VBox style="-fx-padding: 20 24 12 24;">
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <Label style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2D3B45;" text="Tasks" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="addButton" onAction="#onAddButtonClick" text="+ Add Task" />
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-padding: 10 0 0 0;">
                <Label style="-fx-text-fill: #6B7280; -fx-font-size: 12px;" text="Filter by course:" />
                <ComboBox fx:id="courseFilterCombo" prefWidth="200.0" promptText="All courses" />
            </HBox>
        </VBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #ffffff; -fx-background: #ffffff;" BorderPane.alignment="CENTER">
            <content>
                <VBox fx:id="taskListBox" spacing="8.0" style="-fx-padding: 0 24 24 24; -fx-background-color: #ffffff;" />
            </content>
        </ScrollPane>
    </center>
</BorderPane>
