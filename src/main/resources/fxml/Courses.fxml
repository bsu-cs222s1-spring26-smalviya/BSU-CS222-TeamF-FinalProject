<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.StackPane?>

<BorderPane fx:id="anchorPane" prefHeight="704.0" prefWidth="1302.0" style="-fx-background-color: #ffffff;" stylesheets="@../css/Common.css, @../css/Courses.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.wiseplanner.gui.controller.CoursesController">
    <top>
        <Label style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2D3B45;" text="Courses" BorderPane.alignment="CENTER_LEFT">
            <BorderPane.margin>
                <Insets bottom="10.0" left="14.0" top="14.0" />
            </BorderPane.margin>
        </Label>
    </top>
    <center>
        <ScrollPane fx:id="coursesScrollPane" fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" BorderPane.alignment="CENTER">
            <content>
                <StackPane fx:id="contentPane">
                    <FlowPane fx:id="cardsPane" hgap="20.0" prefWrapLength="1000.0" style="-fx-background-color: #ffffff;" vgap="20.0" StackPane.alignment="TOP_LEFT">
                        <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                    </FlowPane>
                </StackPane>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
