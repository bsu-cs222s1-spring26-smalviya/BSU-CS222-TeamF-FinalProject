<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="430.0" prefWidth="450.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.wiseplanner.gui.controller.TaskDetailController">
   <children>
      <VBox layoutX="24.0" layoutY="20.0" prefHeight="390.0" prefWidth="402.0" spacing="10.0">
         <children>
            <Label fx:id="formTitleLabel" text="Add Task">
               <font>
                  <Font size="24.0" />
               </font>
            </Label>
            <Label fx:id="deadlineLabel" text="Deadline" />
            <HBox spacing="8.0">
               <children>
                  <DatePicker fx:id="deadlineDate" prefHeight="34.0" prefWidth="184.0" />
                  <Spinner fx:id="deadlineHour" editable="true" prefHeight="34.0" prefWidth="72.0" />
                  <Label text="H" />
                  <Spinner fx:id="deadlineMinute" editable="true" prefHeight="34.0" prefWidth="72.0" />
                  <Label text="M" />
               </children>
            </HBox>
            <Label fx:id="titleLabel" text="Title" />
            <TextField fx:id="titleTextField" prefHeight="34.0" promptText="Enter task title" />
            <Label fx:id="contentLabel" text="Description" />
            <TextArea fx:id="contentTextArea" prefHeight="190.0" promptText="Write your task details..." wrapText="true" />
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
               <children>
                  <Button fx:id="cancelButton" mnemonicParsing="false" onAction="#onCancelButtonClick" prefHeight="34.0" prefWidth="94.0" text="Cancel" />
                  <Button fx:id="okButton" mnemonicParsing="false" onAction="#onOKButtonClick" prefHeight="34.0" prefWidth="94.0" style="-fx-background-color: #2f80ed; -fx-text-fill: white; -fx-font-weight: bold;" text="OK" />
               </children>
               <padding>
                  <Insets top="6.0" />
               </padding>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>