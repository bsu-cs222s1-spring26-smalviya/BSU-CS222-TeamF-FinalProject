<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="440.0" spacing="8.0"
      style="-fx-background-color: #FFFFFF; -fx-padding: 24;"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.wiseplanner.gui.controller.TaskDetailController">
   <children>
      <Label fx:id="formTitleLabel" text="Add Task"
             style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2D3B45;">
         <VBox.margin><Insets bottom="8.0"/></VBox.margin>
      </Label>

      <Label text="Title" style="-fx-font-weight: bold; -fx-text-fill: #2D3B45;"/>
      <TextField fx:id="titleTextField" promptText="Task title">
         <VBox.margin><Insets bottom="6.0"/></VBox.margin>
      </TextField>

      <Label text="Description" style="-fx-font-weight: bold; -fx-text-fill: #2D3B45;"/>
      <TextArea fx:id="contentTextArea" prefHeight="90.0" promptText="Optional details…" wrapText="true">
         <VBox.margin><Insets bottom="6.0"/></VBox.margin>
      </TextArea>

      <Label text="Deadline" style="-fx-font-weight: bold; -fx-text-fill: #2D3B45;"/>
      <HBox spacing="8.0" alignment="CENTER_LEFT">
         <DatePicker fx:id="deadlineDate" prefWidth="170.0"/>
         <Spinner fx:id="deadlineHour" editable="true" prefWidth="64.0"/>
         <Label text="h" style="-fx-text-fill: #6B7280;"/>
         <Spinner fx:id="deadlineMinute" editable="true" prefWidth="64.0"/>
         <Label text="m" style="-fx-text-fill: #6B7280;"/>
         <VBox.margin><Insets bottom="6.0"/></VBox.margin>
      </HBox>

      <Label text="Assign to Course (optional)" style="-fx-font-weight: bold; -fx-text-fill: #2D3B45;"/>
      <ComboBox fx:id="courseCombo" maxWidth="1.7976931348623157E308" promptText="None (Unassigned)">
         <VBox.margin><Insets bottom="10.0"/></VBox.margin>
      </ComboBox>

      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <Button fx:id="cancelButton" text="Cancel" onAction="#onCancelButtonClick"/>
         <Button fx:id="okButton" text="Save" onAction="#onOKButtonClick"/>
      </HBox>
   </children>
</VBox>