<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="440.0" spacing="8.0" style="-fx-background-color: #FFFFFF; -fx-padding: 24;" stylesheets="@../css/Common.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.wiseplanner.gui.controller.TaskDetailController">
   <children>
      <Label fx:id="formTitleLabel" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2D3B45;" text="Add Task">
         <VBox.margin><Insets bottom="8.0" /></VBox.margin>
      </Label>

      <Label style="-fx-font-weight: bold; -fx-text-fill: #2D3B45;" text="Title" />
      <TextField fx:id="titleTextField" promptText="Task title">
         <VBox.margin><Insets bottom="6.0" /></VBox.margin>
      </TextField>

      <Label style="-fx-font-weight: bold; -fx-text-fill: #2D3B45;" text="Description" />
      <TextArea fx:id="contentTextArea" prefHeight="90.0" promptText="Optional details…" wrapText="true">
         <VBox.margin><Insets bottom="6.0" /></VBox.margin>
      </TextArea>

      <Label style="-fx-font-weight: bold; -fx-text-fill: #2D3B45;" text="Deadline" />
      <HBox alignment="CENTER_LEFT" spacing="8.0">
         <DatePicker fx:id="deadlineDate" prefHeight="40.0" prefWidth="170.0" />
         <Spinner fx:id="deadlineHour" editable="true" prefHeight="40.0" prefWidth="85.0" />
         <Label style="-fx-text-fill: #6B7280;" text="h" />
         <Spinner fx:id="deadlineMinute" editable="true" prefHeight="40.0" prefWidth="85.0" />
         <Label style="-fx-text-fill: #6B7280;" text="m" />
         <VBox.margin><Insets bottom="6.0" /></VBox.margin>
      </HBox>

      <Label style="-fx-font-weight: bold; -fx-text-fill: #2D3B45;" text="Assign to Course (optional)" />
      <ComboBox fx:id="courseCombo" maxWidth="1.7976931348623157E308" promptText="None (Unassigned)">
         <VBox.margin><Insets bottom="10.0" /></VBox.margin>
      </ComboBox>

      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <Button fx:id="cancelButton" onAction="#onCancelButtonClick" text="Cancel" />
         <Button fx:id="okButton" onAction="#onOKButtonClick" text="Save" />
      </HBox>
   </children>
</VBox>
