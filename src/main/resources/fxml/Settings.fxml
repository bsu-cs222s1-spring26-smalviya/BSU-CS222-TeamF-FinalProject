<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
      prefHeight="250.0" prefWidth="400.0"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.wiseplanner.gui.controller.SettingsController">
    <children>
        <Label text="Settings">
            <font><Font size="24.0"/></font>
            <VBox.margin><Insets bottom="20.0" left="10.0" top="20.0"/></VBox.margin>
        </Label>

        <Label text="Name"/>
        <TextField fx:id="nameField">
            <VBox.margin><Insets bottom="10.0" left="10.0" right="10.0" top="5.0"/></VBox.margin>
        </TextField>

        <Label text="Canvas Token"/>
        <TextField fx:id="tokenField">
            <VBox.margin><Insets bottom="10.0" left="10.0" right="10.0" top="5.0"/></VBox.margin>
        </TextField>

        <Label fx:id="statusLabel" text="" style="-fx-text-fill: green;">
            <VBox.margin><Insets left="10.0"/></VBox.margin>
        </Label>

        <Button fx:id="saveButton" text="Save" onAction="#onSaveButtonClick" prefWidth="200.0">
            <VBox.margin><Insets left="100.0" top="10.0"/></VBox.margin>
        </Button>
    </children>
</VBox>