<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="704.0" prefWidth="1302.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.wiseplanner.gui.controller.SchedulesController">
   <top>
      <HBox alignment="CENTER_LEFT" BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="schedulesLabel" text="Schedules">
               <font>
                  <Font size="36.0" />
               </font>
            </Label>
            <HBox prefWidth="0.0" HBox.hgrow="ALWAYS" />
            <Button fx:id="addButton" mnemonicParsing="false" onAction="#onAddButtonClick" text="Add" />
         </children>
         <padding>
            <Insets top="14.0" right="16.0" bottom="10.0" left="14.0" />
         </padding>
      </HBox>
   </top>
   <center>
      <ScrollPane fx:id="scrollPane" fitToWidth="true" BorderPane.alignment="CENTER">
        <content>
          <StackPane fx:id="contentPane">
            <AnchorPane fx:id="schedulesTable" minHeight="0.0" minWidth="0.0" prefHeight="562.0" prefWidth="1268.0" StackPane.alignment="TOP_LEFT" />
          </StackPane>
        </content>
         <BorderPane.margin>
            <Insets right="16.0" left="16.0" />
         </BorderPane.margin>
      </ScrollPane>
   </center>
   <bottom>
      <HBox alignment="CENTER_RIGHT" BorderPane.alignment="CENTER">
         <children>
            <Slider fx:id="zoomSlider" prefWidth="180.0" />
         </children>
         <padding>
            <Insets top="10.0" right="16.0" bottom="14.0" left="16.0" />
         </padding>
      </HBox>
   </bottom>
</BorderPane>
