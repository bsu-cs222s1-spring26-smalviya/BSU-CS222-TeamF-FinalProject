<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="704.0" prefWidth="1302.0"
            style="-fx-background-color: #F5F5F5;"
            stylesheets="@../css/MainWindow.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.wiseplanner.gui.controller.SchedulesController">
   <top>
      <HBox alignment="CENTER_LEFT" style="-fx-padding: 20 24 12 24;">
         <Label text="Schedules"
                style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2D3B45;"/>
         <Region HBox.hgrow="ALWAYS"/>
         <Button fx:id="addButton" text="+ Add Schedule" onAction="#onAddButtonClick"/>
      </HBox>
   </top>
   <center>
      <ScrollPane fitToWidth="true"
                  style="-fx-background-color: #F5F5F5; -fx-background: #F5F5F5;"
                  BorderPane.alignment="CENTER">
         <content>
            <VBox fx:id="scheduleListBox" spacing="8.0"
                  style="-fx-padding: 0 24 24 24; -fx-background-color: #F5F5F5;"/>
         </content>
      </ScrollPane>
   </center>
</BorderPane>