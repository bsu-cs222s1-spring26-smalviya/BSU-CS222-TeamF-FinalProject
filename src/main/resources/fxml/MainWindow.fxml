<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="borderPane" prefHeight="768.0" prefWidth="1366.0"
            stylesheets="@../css/MainWindow.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.wiseplanner.gui.controller.MainWindowController">
   <top>
      <HBox fx:id="topBar" alignment="CENTER_LEFT" prefHeight="60.0" spacing="12.0"
            BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="backButton" onAction="#onBackButtonClick"
                    prefHeight="34.0" prefWidth="34.0" text="←">
               <HBox.margin><Insets left="16.0"/></HBox.margin>
            </Button>
            <Label text="WisePlanner"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;">
               <HBox.margin><Insets left="4.0"/></HBox.margin>
            </Label>
            <Region HBox.hgrow="ALWAYS"/>
            <MenuButton fx:id="userMenuButton" text="User" contentDisplay="LEFT">
               <items>
                  <MenuItem fx:id="settingsMenuItem" text="⚙  Settings"
                            onAction="#onSettingsMenuItemClick"/>
                  <SeparatorMenuItem/>
                  <MenuItem fx:id="logoutMenuItem" text="↩  Log Out"
                            onAction="#onLogoutMenuItemClick"/>
               </items>
               <graphic>
                  <Label fx:id="avatarLabel" alignment="CENTER"
                         prefHeight="30.0" prefWidth="30.0"
                         style="-fx-background-radius: 15;"/>
               </graphic>
               <HBox.margin><Insets right="16.0"/></HBox.margin>
            </MenuButton>
         </children>
         <padding><Insets top="0" bottom="0"/></padding>
      </HBox>
   </top>
   <left>
      <VBox fx:id="navigationBar" prefHeight="708.0" prefWidth="0.0" BorderPane.alignment="CENTER"/>
   </left>
   <center>
      <StackPane fx:id="pagePane" prefWidth="1366.0" BorderPane.alignment="CENTER"/>
   </center>
</BorderPane>