<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="borderPane" prefHeight="768.0" prefWidth="1366.0"
            stylesheets="@../css/MainWindow.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.wiseplanner.gui.controller.MainWindowController">
   <top>
      <HBox fx:id="topBar" alignment="CENTER_LEFT" prefHeight="64.0" spacing="12.0" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="backButton" onAction="#onBackButtonClick"
                    prefHeight="36.0" prefWidth="36.0" text="←">
               <HBox.margin><Insets left="20.0" top="14.0"/></HBox.margin>
            </Button>
            <Label prefHeight="114.0" prefWidth="238.0" text="Wise Planner">
               <font><Font size="36.0"/></font>
               <HBox.margin><Insets left="20.0"/></HBox.margin>
            </Label>
            <Region HBox.hgrow="ALWAYS"/>
            <MenuButton fx:id="userMenuButton" text="User" contentDisplay="LEFT"
                        style="-fx-background-color: transparent; -fx-font-size: 14px; -fx-cursor: hand;">
               <items>
                  <MenuItem fx:id="settingsMenuItem" text="⚙  Settings"
                            onAction="#onSettingsMenuItemClick"/>
                  <SeparatorMenuItem/>
                  <MenuItem fx:id="logoutMenuItem" text="↩  Log Out"
                            onAction="#onLogoutMenuItemClick"/>
               </items>
               <graphic>
                  <Label fx:id="avatarLabel" alignment="CENTER"
                         prefHeight="32.0" prefWidth="32.0"
                         style="-fx-background-radius: 16;"/>
               </graphic>
               <HBox.margin><Insets right="20.0"/></HBox.margin>
            </MenuButton>
         </children>
      </HBox>
   </top>
   <left>
      <VBox fx:id="navigationBar" prefHeight="704.0" prefWidth="0.0" BorderPane.alignment="CENTER"/>
   </left>
   <center>
      <StackPane fx:id="pagePane" prefWidth="1366.0" BorderPane.alignment="CENTER"/>
   </center>
</BorderPane>