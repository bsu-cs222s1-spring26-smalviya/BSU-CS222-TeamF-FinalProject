<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="borderPane" prefHeight="768.0" prefWidth="1366.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.wiseplanner.gui.controller.MainWindowController">
   <top>
      <HBox fx:id="topBar" prefHeight="64.0" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="backButton" onAction="#onBackButtonClick" prefHeight="36.0" prefWidth="36.0" text="←">
               <HBox.margin><Insets left="20.0" top="14.0" /></HBox.margin>
            </Button>
            <Label prefHeight="114.0" prefWidth="238.0" text="Wise Planner">
               <font>
                  <Font size="36.0" />
               </font>
               <HBox.margin>
                  <Insets left="20.0" />
               </HBox.margin>
            </Label>
         </children></HBox>
   </top>
   <left>
      <VBox fx:id="navigationBar" prefHeight="704.0" prefWidth="80.0" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="coursesButton" mnemonicParsing="false" onAction="#onCoursesButtonClick" prefHeight="64.0" prefWidth="80.0" text="Courses" />
            <Button fx:id="tasksButton" mnemonicParsing="false" onAction="#onTasksButtonClick" prefHeight="64.0" prefWidth="80.0" text="Tasks" />
            <Button fx:id="schedulesButton" mnemonicParsing="false" onAction="#onSchedulesButtonClick" prefHeight="64.0" prefWidth="80.0" text="Schedules" />
            <Button fx:id="settingsButton" mnemonicParsing="false" onAction="#onSettingsButtonClick" prefHeight="64.0" prefWidth="80.0" text="Settings" />
         </children></VBox>
   </left>
   <center>
      <StackPane fx:id="pagePane" prefWidth="1242.0" BorderPane.alignment="CENTER" />
   </center>
</BorderPane>
